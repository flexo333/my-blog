---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About — William Bright"
  description="About William Bright."
>
  <div class="container page">

    <header class="page-header">
      <img src="/avatar.jpg" alt="William Bright" class="avatar" />
      <h1 class="page-title">William Bright</h1>
    </header>

    <div class="prose about-prose">

      <p>
        I'm a problem solver at heart. I am never happier than when elbow deep in some messy,
        complex situation. I'm a lifelong learner.
      </p>

      <p>
        At home, I am father to three kids, trying to not make too many mistakes along the way.
        When I have the chance, I am in nature — a trail run or overnight hike away from it all.
      </p>

      <p>This is where I write things down to figure out what I think.</p>

    </div>

    <div class="links">
      <a href="/blog">Writing</a>
      <span aria-hidden="true">·</span>
      <a href="/#projects">Projects</a>
    </div>

  </div>
</Layout>

<style>
  .page {
    padding-top: 4rem;
    padding-bottom: 5rem;
    max-width: 580px;
  }

  .page-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border-light);
  }

  .avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    flex-shrink: 0;
    border: 2px solid var(--border-light);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .about-prose p {
    margin-bottom: 1.4rem;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .about-prose p:last-child { margin-bottom: 0; }

  .links {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-light);
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--muted);
    display: flex;
    gap: 0.6rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .links a { color: var(--muted); text-decoration: none; }
  .links a:hover { color: var(--link); }
</style>
